# Supabase project credentials — get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Stitch / Google API key for external services (DO NOT commit the real key)
# Example: STITCH_GOOGLE_API_KEY=your-google-api-key
# Set the real key in your local `.env.local` or a secret manager before running.
STITCH_BASE_URL=https://your-stitch-base.example

# Paystack settings for membership checkout
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=your-paystack-public-key
PAYSTACK_SECRET_KEY=your-paystack-secret-key
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Nalo SMS API Gateway Settings
NALO_SMS_USERNAME=your-username
NALO_SMS_PASSWORD=your-password
NALO_SMS_SENDER_ID=your-sender-id
# NALO_SMS_RESELLER=Resl_Nalo
# NALO_SMS_API_URL=https://sms.nalosolutions.com/smsbackend/clientapi/Resl_Nalo/send-message/
